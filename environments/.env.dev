NODE_ENV=development

# En desarrollo usa proxy local para evitar CORS
VITE_API_URL=https://localhost:8083
VITE_APP_NAME=Buró de Crédito
VITE_APP_VERSION=2.0.0
VITE_NAME_PROJECT=buro-credito

# Keycloak - en desarrollo usa proxy local para evitar CORS/cookies cross-origin
VITE_KEYCLOAK_URL=/auth
VITE_KEYCLOAK_PROXY_TARGET=https://srv-portaldev.nafin.com
VITE_KEYCLOAK_REALM=NAFIN
VITE_KEYCLOAK_CLIENT_ID=buro-credito

# Features
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_DEVTOOLS=false

# Log Level
VITE_LOG_LEVEL=error

# Session
VITE_SESSION_TIMEOUT=30
VITE_SESSION_WARNING_BEFORE_TIMEOUT=5

# Roles
VITE_ROLE_ADMIN_ID=administrador

# Fecha limite para modificar el portafolio (formato: YYYY-MM-DDTHH:mm:ss)
# @deprecated — Los bloqueos ahora se configuran desde /bloqueos (Admin) vía API
VITE_EDIT_DEADLINE=

# Environment
VITE_AMBIENTE=production
VITE_ENVIRONMENT=production
