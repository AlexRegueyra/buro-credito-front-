# Copia este archivo como .env para desarrollo local
NODE_ENV=development

# API Buró de Crédito (Spring Boot)
VITE_API_URL=http://localhost:8083
VITE_APP_NAME=Buró de Crédito
VITE_APP_VERSION=1.0.0
VITE_NAME_PROJECT=

# Keycloak
VITE_KEYCLOAK_URL=http://localhost:8080/auth
VITE_KEYCLOAK_REALM=buro-credito
VITE_KEYCLOAK_CLIENT_ID=buro-credito-front
# Desactivar Keycloak en local si no hay servidor: true | false
VITE_BYPASS_KEYCLOAK=false

# Feature Flags
VITE_ENABLE_DEBUG=true
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_DEVTOOLS=true

# PFAE — deshabilitado hasta tener contrato/credenciales/datos validados.
VITE_PFAE_ENABLED=false
# Solo local: habilita PFAE con respuesta mock (no llama endpoints reales).
VITE_PFAE_MOCK_ENABLED=false

# Sesión (ms)
VITE_SESSION_TIMEOUT=1800000
VITE_SESSION_WARNING=120000

VITE_LOG_LEVEL=debug
