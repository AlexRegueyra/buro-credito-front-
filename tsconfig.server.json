{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // ── Entorno Node.js ───────────────────────────────────────────────────────
    "lib": ["ES2022"],
    "types": ["node"],

    // ── Sin DOM ───────────────────────────────────────────────────────────────
    // El servidor no tiene window, document, ni import.meta.env de Vite.
    // Eliminar "DOM" y "DOM.Iterable" que hereda del tsconfig base.

    // ── Módulos ───────────────────────────────────────────────────────────────
    // "Bundler" funciona para type-checking cuando esbuild hace el build real.
    "moduleResolution": "Bundler",
    "module": "ESNext",

    // ── Emit ──────────────────────────────────────────────────────────────────
    // noEmit: true → este tsconfig es solo para type-checking.
    // esbuild se encarga del bundle real (ver scripts en package.json).
    "noEmit": true,
    "allowImportingTsExtensions": true,

    // ── Relajar reglas de linting que chocan con patrones de Express ──────────
    // Express requiere firmas como (err, req, res, next) aunque no uses err.
    "noUnusedParameters": false,

    // ── JSX no aplica al servidor ─────────────────────────────────────────────
    "jsx": "preserve"
  },
  "include": [
    "src/server/**/*",
    "src/shared/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/features/**/*",
    "src/app/**/*",
    "src/lib/**/*",
    "src/main.tsx"
  ]
}
