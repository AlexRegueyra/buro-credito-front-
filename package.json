{
  "name": "buro-credito-front",
  "author": "DGA TI",
  "licence": "MIT",
  "version": "1.0.0",
  "private": true,
  "homepage": "/buro-credito",
  "type": "module",
  "scripts": {
    "dev": "node ./tools/run-compilation.js dev && vite",
    "dev:local": "node ./tools/run-compilation.js local && vite",
    "dev:staging": "node ./tools/run-compilation.js staging && vite",
    "dev:production": "node ./tools/run-compilation.js production && vite",
    "build": "node ./tools/run-compilation.js production && tsc && vite build --mode production",
    "build:dev": "node ./tools/run-compilation.js dev && tsc && vite build --mode development",
    "build:staging": "node ./tools/run-compilation.js staging && tsc && vite build --mode staging",
    "build:production": "node ./tools/run-compilation.js production && tsc && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\""
  },
  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@hookform/resolvers": "^3.9.1",
    "@iconify/react": "^6.0.0",
    "@mui/icons-material": "^7.3.2",
    "@mui/lab": "^7.0.0-beta.12",
    "@mui/material": "^7.3.2",
    "@mui/utils": "^7.0.0",
    "@tanstack/react-query": "^5.62.16",
    "@tanstack/react-virtual": "^3.11.2",
    "axios": "^1.7.7",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.22",
    "keycloak-js": "^26.2.0",
    "lodash": "^4.17.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.9.3",
    "simplebar-react": "^3.2.7",
    "uuid": "^11.0.3",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.16",
    "@types/node": "^22.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "fs-extra": "^11.3.3",
    "jsdom": "^27.0.0",
    "listr": "^0.14.3",
    "prettier": "^3.4.2",
    "terser": "^5.46.0",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^3.2.4"
  }
}
