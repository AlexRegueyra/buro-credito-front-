    "server:type-check": "tsc --project tsconfig.server.json",
    "start": "node ./tools/run-compilation.js local && vite",
    "start:local": "node ./tools/run-compilation.js local && vite",
    "start:mock": "node ./tools/run-compilation.js mock && vite",
    "start:dev": "node ./tools/run-compilation.js dev && vite",
    "start:staging": "node ./tools/run-compilation.js staging && vite",
