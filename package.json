    "dev:mock": "node ./tools/run-compilation.js mock && vite",
    "dev:staging": "node ./tools/run-compilation.js staging && vite",
    "dev:production": "node ./tools/run-compilation.js production && vite",
    "build": "node ./tools/run-compilation.js production && tsc && vite build --mode production",
    "build:local": "node ./tools/run-compilation.js local && tsc && vite build --mode development",
    "build:mock": "node ./tools/run-compilation.js mock && tsc && vite build --mode development",
    "build:dev": "node ./tools/run-compilation.js dev && tsc && vite build --mode development",
    "build:staging": "node ./tools/run-compilation.js staging && tsc && vite build --mode staging",
    "build:production": "node ./tools/run-compilation.js production && tsc && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:run && npm run test:e2e",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
